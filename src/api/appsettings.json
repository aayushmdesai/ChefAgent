{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "Qdrant": {
    "Endpoint": "http://localhost:6334",
    "CollectionName": "recipes"
  },
  "Ollama": {
    "Endpoint": "http://localhost:11434",
    "ChatModel": "llama3.2",
    "EmbeddingModel": "nomic-embed-text",
    "TimeoutSeconds": 120
  },
 "Redis": {
    "ConnectionString": "localhost:6379",
    "ConnectTimeoutMs": 2000,
    "SyncTimeoutMs": 2000,
    "AsyncTimeoutMs": 2000
},
  "CircuitBreaker": {
    "FailureThreshold": 3,
    "CooldownSeconds": 60
  },
  "RateLimiter": {
    "PerSessionLimit": 30,
    "GlobalLimit": 100,
    "WindowSeconds": 60
  },
  "InputGuard": {
    "MaxLength": 500,
    "MinLength": 2
  }
}