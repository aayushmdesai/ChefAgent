{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    },
    "Console": {
      "IncludeScopes": true
    }
  },
  "AllowedHosts": "*",
  "Qdrant": {
    "Endpoint": "http://localhost:6334",
    "CollectionName": "recipes"
  },
  "Ollama": {
    "Endpoint": "http://localhost:11434",
    "ChatModel": "llama3.2",
    "EmbeddingModel": "nomic-embed-text",
    "TimeoutSeconds": 120
  },
 "Redis": {
    "ConnectionString": "localhost:6379",
    "ConnectTimeoutMs": 2000,
    "SyncTimeoutMs": 2000,
    "AsyncTimeoutMs": 2000
},
  "CircuitBreaker": {
    "FailureThreshold": 3,
    "CooldownSeconds": 60
  },
  "RateLimiter": {
    "PerSessionLimit": 30,
    "GlobalLimit": 100,
    "WindowSeconds": 60
  },
  "InputGuard": {
    "MaxLength": 500,
    "MinLength": 2
  },
  "Langfuse": {
    "Enabled": true,
    "BaseUrl": "http://langfuse-server:3000",
    "PublicKey": "pk-lf-local",
    "SecretKey": "sk-lf-local",
    "BatchSize": 20,
    "FlushIntervalSeconds": 2
  }
}